# Токен бота от @BotFather
BOT_TOKEN=

# ID админов через запятую (telegram user id)
ADMIN_IDS=

# Подключение к общему PostgreSQL (от ShopBot).
# Хост "db" — имя контейнера postgres в сети shop-bot.
# На VPS создать базу: docker exec shop-bot-db-1 psql -U shopbot -c "CREATE DATABASE bookingbot;"
DATABASE_URL=postgresql+asyncpg://shopbot:shopbot_secret@db:5432/bookingbot

# За сколько минут до записи отправлять напоминание
REMINDER_MINUTES=60

# Название бизнеса
BUSINESS_NAME=Студия красоты

# Начало и конец рабочего дня (часы, для справки/дефолтов)
WORK_START_HOUR=9
WORK_END_HOUR=21
